{
  "name": "leash-secrets",
  "version": "1.1.0",
  "description": "Keep your secrets on a leash — AI agent skill that catches exposed API keys, tokens, and credentials before they hit your codebase",
  "main": "src/index.js",
  "bin": {
    "leash-secrets": "bin/leash-secrets.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node scripts/check-patterns.js && node tests/test-patterns.js",
    "check-patterns": "node scripts/check-patterns.js",
    "validate": "node scripts/check-patterns.js",
    "scan": "node bin/leash-secrets.js scan",
    "prepare-extension": "node scripts/prepare-vscode-extension.js",
    "package-extension": "npm run prepare-extension && cd vscode-extension && npm run package",
    "benchmark": "node scripts/benchmark-summary.js",
    "verify": "bash scripts/verify-hygiene.sh",
    "docs:serve": "mkdocs serve",
    "docs:build": "mkdocs build --strict",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "security",
    "secrets",
    "api-keys",
    "credentials",
    "secret-detection",
    "secret-scanning",
    "ai-agent",
    "cursor",
    "claude-code",
    "codex",
    "copilot",
    "gemini",
    "windsurf",
    "cline",
    "pre-commit",
    "devsecops",
    "leash-secrets"
  ],
  "author": "eeshu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FasterApiWeb/leash-secrets.git"
  },
  "bugs": {
    "url": "https://github.com/FasterApiWeb/leash-secrets/issues"
  },
  "homepage": "https://github.com/FasterApiWeb/leash-secrets#readme",
  "files": [
    "src/",
    "bin/",
    "skills/",
    "patterns/",
    "hooks/",
    "scripts/",
    "AGENTS.md",
    ".cursor/rules/leash-secrets.mdc",
    ".github/copilot-instructions.md"
  ]
}
